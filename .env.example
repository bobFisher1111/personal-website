# Copy this file to `.env.local` for local development.
# For Vercel: set these in Project Settings → Environment Variables.
# Note: Vite only exposes variables prefixed with VITE_.

# Optional. Defaults to window.location.origin if not set.
VITE_APP_BASE_URL=

# Optional alias for VITE_APP_BASE_URL. If both are set, VITE_APP_BASE_URL wins.
VITE_WEBSITE_URL=

# Optional
VITE_FACEBOOK_URL=
VITE_YOUTUBE_URL=
VITE_TWITTER_URL=

# Required
VITE_USER_AGREEMENT_VALUE=
VITE_WEBSITE_EMAIL=
VITE_SITE_NAME=

# Optional
VITE_HOMEPAGE_IMAGE=

# Legacy typo supported (prefer VITE_WEBSITE_EMAIL)
# VITE_WEBSTIE_EMAIL=
