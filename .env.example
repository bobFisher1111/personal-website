# Copy this file to `.env.local` for local development.
# For Vercel: set these in Project Settings → Environment Variables.
# Note: Vite only exposes variables prefixed with VITE_.

# Optional. Defaults to window.location.origin if not set.
VITE_APP_BASE_URL=

# Required
VITE_API_BASE_URL=
VITE_FACEBOOK_URL=
VITE_YOUTUBE_URL=
VITE_TWITTER_URL=
VITE_USER_AGREEMENT_VALUE=
VITE_WEBSITE_API_URL=
VITE_WEBSITE_EMAIL=
VITE_HOMEPAGE_IMAGE=
VITE_SITE_NAME=
VITE_WEBSITE_URL=

# Legacy typo supported (prefer VITE_WEBSITE_EMAIL)
# VITE_WEBSTIE_EMAIL=
